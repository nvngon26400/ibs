				</exclusion>
			</exclusions>
		</dependency>
		
		<!--xls-->
		<dependency>
			<groupId>org.apache.poi</groupId>
			<artifactId>poi</artifactId>
			<version>4.1.2</version>
		</dependency>

		<!--xlsx-->
		<dependency>
			<groupId>org.apache.poi</groupId>
			<artifactId>poi-ooxml</artifactId>
			<version>4.1.2</version>
		</dependency>
	</dependencies>

	<profiles>
		<!-- Production -->
		<profile>
			<id>prod</id>
			<build>
				<plugins>
					<plugin>
						<artifactId>maven-antrun-plugin</artifactId>
						<executions>
							<execution>
								<id>maven-antrun</id>
								<phase>compile</phase>
								<goals>
									<goal>run</goal>
								</goals>
								<configuration>
									<target>
										<copy
											file="${basedir}/src/main/resources/${logback.prod}"
											tofile="${project.build.outputDirectory}/${logback.base}"
											overwrite="true" failonerror="false" />
									</target>
								</configuration>
							</execution>
						</executions>
					</plugin>
					<plugin>
						<groupId>org.apache.maven.plugins</groupId>
						<artifactId>maven-compiler-plugin</artifactId>
						<configuration>
						    <excludes>
								<!-- テストツールの本番リリース除外設定 -->
						        <exclude>com/sbisec/helios/common/testtool/**</exclude>
						        <exclude>com/sbisec/helios/common/unittest/**</exclude>
						        <exclude>com/sbisec/helios/gw/testtool/**</exclude>
						        <exclude>com/sbisec/helios/ap/testtool/**</exclude>
						    </excludes>
						</configuration>
					</plugin>
				</plugins>
			</build>
			<properties>
				<url.horus.pl>http://localhost:8080/horus-pl</url.horus.pl>
				<url.helios.ap>http://localhost:8089</url.helios.ap>
				<cors.crossorigins>http://localhost:9528,http://localhost:9529</cors.crossorigins>
			</properties>
		</profile>
		<!-- Develop (default) -->
		<profile>
			<id>dev</id>
			<activation>
				<activeByDefault>true</activeByDefault>
			</activation>
			<properties>
				<url.horus.pl>http://localhost:8080/horus-pl</url.horus.pl>
				<url.helios.ap>http://localhost:8089</url.helios.ap>
				<cors.crossorigins>http://localhost:9528,http://localhost:9529</cors.crossorigins>
			</properties>
		</profile>
		<!-- Develop (Tomcat standalone) -->
		<profile>
			<id>dev_standalone</id>
			<properties>
				<url.horus.pl>http://localhost:8080/horus-pl</url.horus.pl>
				<url.helios.ap>http://localhost:8089/ap</url.helios.ap>
				<cors.crossorigins>http://localhost:9528,http://localhost:9529</cors.crossorigins>
			</properties>
		</profile>
