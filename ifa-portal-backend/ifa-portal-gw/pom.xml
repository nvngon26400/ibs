	<properties>
		<project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
		<project.reporting.outputEncoding>UTF-8</project.reporting.outputEncoding>
		<!-- java.versionについては17が正だがSpringframeworkのバージョンとミスマッチが生じるため暫定で11とする -->
		<java.version>11</java.version>
		<logback.prod>logback-spring-prod.xml</logback.prod>
		<logback.dev>logback-spring-dev.xml</logback.dev>
		<logback.base>logback-spring.xml</logback.base>
	</properties>

	<dependencies>
		<dependency>
			<groupId>org.springframework.boot</groupId>
			<artifactId>spring-boot-starter-web</artifactId>
			<exclusions>
				<exclusion>
					<groupId>org.springframework.boot</groupId>
					<artifactId>spring-boot-starter-tomcat</artifactId>
				</exclusion>
				<exclusion>
					<groupId>com.fasterxml.jackson.core</groupId>
					<artifactId>jackson-databind</artifactId>
				</exclusion>
