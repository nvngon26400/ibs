<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<!--
    画面ID：SUB0201_03-01
    画面名：顧客一覧・先OP
-->
<mapper namespace="com.sbisec.helios.ap.brokerageMenu.customerList.dao.mapper.IfaCustomerListFuturesOptionsMapper">
    <!-- 全角が入る場合はtypeHandler="com.sbibits.earth.dao.typehandler.StringTypeHandler"を設定すること -->
    <!-- 住所が入る場合はtype="com.sbibits.horus.ap.common.typehandler.AddressConvertHandler"を設定すること -->

    <resultMap id="ResultMapIfaCustomerListFuturesOptionsSql001" type="com.sbisec.helios.ap.brokerageMenu.customerList.dao.model.IfaCustomerListFuturesOptionsSql001ResponseModel" >
        <result property="nameKana" column="NAME_KANA" typeHandler="com.sbibits.earth.dao.typehandler.StringTypeHandler"/>
        <result property="nameKanji" column="NAME_KANJI" typeHandler="com.sbibits.earth.dao.typehandler.StringTypeHandler"/>
        <result property="brokerChargeName" column="BROKER_CHARGE_NAME" typeHandler="com.sbibits.earth.dao.typehandler.StringTypeHandler"/>
        <result property="branchName" column="BRANCH_NAME" typeHandler="com.sbibits.earth.dao.typehandler.StringTypeHandler"/>
        <result property="branchNameHead" column="BRANCH_NAME_HEAD" typeHandler="com.sbibits.earth.dao.typehandler.StringTypeHandler"/>
        <result property="customerAttributeName" column="CUSTOMER_ATTRIBUTE_NAME" typeHandler="com.sbibits.earth.dao.typehandler.StringTypeHandler"/>
    </resultMap>
    <!--
        SQLID：Sql001
        SQL名：顧客検索
        SQLタイプ：select
    -->
    <select id="selectIfaCustomerListFuturesOptionsSql001" resultMap="ResultMapIfaCustomerListFuturesOptionsSql001" statementType="PREPARED">
        SELECT /* @SQLID=SUB0201_03-01#Sql001 */ *
            FROM (
            SELECT
                  count(*) over () as totalRow
                ,   A.TC_COMP_RANK
                ,   A.NAME_KANA
                ,   A.NAME_KANJI
                ,   A.ACCOUNT_NUMBER
                ,   MCI1.BROKER_BRANCH_CODE
                ,   A.BROKER_CODE
                ,   A.INTERMEDIARY_EMP_CD
                ,   A.BUTEN_CODE
                ,   MC.BROKER_CHARGE_NAME
                ,   G.BRANCH_NAME
                ,   MB.BRANCH_NAME AS BRANCH_NAME_HEAD
                ,   nvl(UA.FU_OP_REQUIRE_MARGIN, 0) FU_OP_REQUIRE_MARGIN
                ,   nvl(UA.FU_OP_ACCEPT_MARGIN, 0) FU_OP_ACCEPT_MARGIN
                ,   nvl(UA.PROF_LOSS_FU_OP, 0) PROF_LOSS_FU_OP
                ,   CAM.CUSTOMER_ATTRIBUTE_NAME
            FROM
                  MEDIATE_USER_ATTRIBUTE_INFO A
                LEFT OUTER JOIN MEDIATE_CHARGE_INFO MCI1
                    ON MCI1.BROKER_CODE = A.BROKER_CODE
                    AND MCI1.BROKER_CHARGE_CODE = A.INTERMEDIARY_EMP_CD
                    AND (
                        SELECT
                            COUNT(*)
                        FROM
                            MEDIATE_CHARGE_INFO MCI2
                        WHERE
                            A.BROKER_CODE = MCI2.BROKER_CODE
                            AND A.INTERMEDIARY_EMP_CD = MCI2.BROKER_CHARGE_CODE
                    ) = 1
                LEFT OUTER JOIN MEDIATE_BRANCH G
                    ON G.BROKER_CODE = A.BROKER_CODE
                    AND MCI1.BROKER_BRANCH_CODE = G.BROKER_BRANCH_CODE
                LEFT OUTER JOIN USER_ATTRIBUTE UA
                    ON A.CUSTOMER_ID = UA.CUSTOMER_ID
                LEFT OUTER JOIN CUSTOMER_ATTRIBUTE_MASTER CAM
                    ON A.CUSTOMER_ATTRIBUTE = CAM.CUSTOMER_ATTRIBUTE
                LEFT OUTER JOIN MEDIATE_BRANCH MB
                    ON A.BROKER_CODE = MB.BROKER_CODE
                    AND MB.BROKER_BRANCH_KIND = '00'
                LEFT OUTER JOIN (
                    SELECT DISTINCT
                        BROKER_CODE
                        , BROKER_CHARGE_CODE
                        , CASE BROKER_CHARGE_CODE
                            WHEN '0000' THEN ''
                            ELSE BROKER_CHARGE_NAME
                            END BROKER_CHARGE_NAME
                    FROM
                        MEDIATE_CHARGE_INFO
                    WHERE
                        DELETE_FLG &lt;> '1'
                ) MC
                    ON A.BROKER_CODE = MC.BROKER_CODE
                    AND A.INTERMEDIARY_EMP_CD = MC.BROKER_CHARGE_CODE
                , (
                        SELECT
                            CUSTOMER_ID
                        FROM
                            USER_INFO_ASSETS
                        WHERE
                            TARGET_FLG = '10'
                            AND ASSETS > 0
                        GROUP BY
                            CUSTOMER_ID
                    ) UIA
            WHERE
                A.CUSTOMER_ID = UIA.CUSTOMER_ID
                 <if test='! req.brokerCodesExclude.empty'>
                     AND A.BROKER_CODE NOT IN
                     <foreach item="item" collection="req.brokerCodesExclude" index="i" open="(" separator="," close=")">
                         #{item}
                     </foreach>
                 </if>
                 <if test='! req.brokerCodes.empty'>
                     AND A.BROKER_CODE IN
                     <foreach item="item" collection="req.brokerCodes" index="i" open="(" separator="," close=")">
                         #{item}
                     </foreach>
                 </if>
                 <if test='req.branchCode != null and req.branchCode != ""'>
                     AND MCI1.BROKER_BRANCH_CODE = #{req.branchCode}
                 </if>
                 <if test='req.empCode != null and req.empCode != ""'>
                     AND A.INTERMEDIARY_EMP_CD = #{req.empCode}
                 </if>
                 <if test='req.butenCode != null and req.butenCode != ""'>
                     AND A.BUTEN_CODE = #{req.butenCode}
                 </if>
                 <if test='req.accountNumber != null and req.accountNumber != ""'>
                     AND A.ACCOUNT_NUMBER = TO_NUMBER(#{req.accountNumber})
                 </if>
                 <if test='req.customerNameKanjiKana != null and req.customerNameKanjiKana != ""'>
                        AND (
                             REGEXP_LIKE(A.NAME_KANJI, #{req.customerNameKanjiKana})
                         OR  REGEXP_LIKE(A.NAME_KANA, #{req.customerNameKanjiKana})
                            )
                 </if>
                 <if test='! req.courses.empty'>
                     AND A.CUSTOMER_ATTRIBUTE IN
                     <foreach item="item" collection="req.courses" index="i" open="(" separator="," close=")">
                         #{item}
                     </foreach>
                 </if>
                 <if test='req.necessaryEntrustDepositFrom != null and req.necessaryEntrustDepositFrom != ""'>
                     AND UA.FU_OP_REQUIRE_MARGIN >= #{req.necessaryEntrustDepositFrom}
                 </if>
                 <if test='req.necessaryEntrustDepositTo != null and req.necessaryEntrustDepositTo != ""'>
                     AND UA.FU_OP_REQUIRE_MARGIN &lt;= #{req.necessaryEntrustDepositTo}
                 </if>
                 <if test='req.marginMoneyFrom != null and req.marginMoneyFrom != ""'>
                     AND UA.FU_OP_ACCEPT_MARGIN >= #{req.marginMoneyFrom}
                 </if>
                 <if test='req.marginMoneyTo != null and req.marginMoneyTo != ""'>
                     AND UA.FU_OP_ACCEPT_MARGIN &lt;= #{req.marginMoneyTo}
                 </if>
                 <if test='req.beforeProfitAndLossFrom != null and req.beforeProfitAndLossFrom != ""'>
                     AND UA.PROF_LOSS_FU_OP >= #{req.beforeProfitAndLossFrom}
                 </if>
                 <if test='req.beforeProfitAndLossTo != null and req.beforeProfitAndLossTo != ""'>
                     AND UA.PROF_LOSS_FU_OP &lt;= #{req.beforeProfitAndLossTo}
                 </if>
                 <choose>
                <when test='req.privId == "1"'>
                    AND 1 = 1
                </when>
                <when test='req.privId == "3" or req.privId == "4" or req.privId == "5"'>
                    AND(A.BROKER_CODE IN
                    <foreach item="brokerChargeList" index="index" collection="req.brokerChargeList" open="(" close=")">
                        <if test="index%1000 == 0 and index!=0">
                            ) OR A.BROKER_CODE IN (
                        </if>
                        <if test="index%1000 != 0">
                            ,
                        </if>
                        #{brokerChargeList.brokerCode}
                    </foreach>
                    )
                </when>
                <otherwise>
                    AND((A.BROKER_CODE, A.INTERMEDIARY_EMP_CD) IN
                    <foreach item="brokerChargeList" index="index" collection="req.brokerChargeList" open="(" close=")">
                        <if test="index%1000 == 0 and index!=0">
                            ) OR (A.BROKER_CODE, A.INTERMEDIARY_EMP_CD) IN (
                        </if>
                        <if test="index%1000 != 0">
                            ,
                        </if>
                        (#{brokerChargeList.brokerCode}, #{brokerChargeList.empCode})
                    </foreach>
                    )
                </otherwise>
            </choose>
             ORDER BY A.BROKER_CODE,A.BUTEN_CODE,A.ACCOUNT_NUMBER
         ) WHERE ROWNUM &lt;= #{req.searchLimitRow}
    </select>
</mapper>
