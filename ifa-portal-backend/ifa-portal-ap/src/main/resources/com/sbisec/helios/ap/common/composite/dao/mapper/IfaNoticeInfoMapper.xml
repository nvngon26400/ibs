<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<!-- 
    画面ID：SUB0202_00-03
    画面名：注意情報
-->
<mapper namespace="com.sbisec.helios.ap.common.composite.dao.mapper.IfaNoticeInfoMapper">
    <!-- 全角が入る場合はtypeHandler="com.sbibits.earth.dao.typehandler.StringTypeHandler"を設定すること -->
    <!-- 住所が入る場合はtype="com.sbibits.horus.ap.common.typehandler.AddressConvertHandler"を設定すること -->
    
    <resultMap id="ResultMapIfaNoticeInfoSql001" type="com.sbisec.helios.ap.common.composite.model.IfaNoticeInfoSql001ResponseModel" >
    </resultMap>
    
    <resultMap id="ResultMapIfaNoticeInfoSql002" type="com.sbisec.helios.ap.common.composite.model.IfaNoticeInfoSql002ResponseModel" >
    </resultMap>
    
    <resultMap id="ResultMapIfaNoticeInfoSql003" type="com.sbisec.helios.ap.common.composite.model.IfaNoticeInfoSql003ResponseModel" >
    </resultMap>
    
    
    <!-- 
        SQLID：Sql001
        SQL名：注意情報取得
        SQLタイプ：select
    -->
    <select id="selectIfaNoticeInfoSql001" resultMap="ResultMapIfaNoticeInfoSql001" statementType="PREPARED">
        SELECT　/* @SQLID=SUB0202_00-03#Sql001 */
            A.CATEGORY as cautionKind
            , A.ATTENTION as memo
            , A.OCCURRENCE_DATE as accuralDate
            , B.AGENT_NAME as dealtPerson
            , A.DELETE_TIME as deleteTime
            
        FROM
            ATTENTION_INFO A 
            LEFT OUTER JOIN AGENT_MASTER B 
                ON A.AGENT_ID = B.AGENT_ID 
        WHERE
            A.CUSTOMER_ID = #{req.customerCode} 
            AND A.ON_OFF_FLG = '有効'
    </select>
    
    <!-- 
        SQLID：Sql002
        SQL名：重要なお知らせによる取引制限取得
        SQLタイプ：select
    -->
    <select id="selectIfaNoticeInfoSql002" resultMap="ResultMapIfaNoticeInfoSql002" statementType="PREPARED">
        SELECT /* @SQLID=SUB0202_00-03#Sql002 */
            A.JUS_RESTRAINT as restRaint
            , A.JUS_RESTRAINT_DATE as restRaintDate
        FROM
            JMSG_USER_STATUS A
        WHERE
            A.JUS_BUTEN_CODE = #{req.butenCode}
            AND A.JUS_ACCOUNT_NUMBER = TO_NUMBER(#{req.accountNumber})
            AND A.JUS_CONFIRM_KBN = '0'
            AND A.JUS_RESTRAINT &lt;&gt; LPAD('0',100,'0')
        ORDER BY
            A.JUS_RESTRAINT_DATE DESC
    </select>
    
    <!-- 
        SQLID：Sql003
        SQL名：重要なお知らせによる取引制限の制限番号に対する制限内容の表示文言取得
        SQLタイプ：select
    -->
    <select id="selectIfaNoticeInfoSql003" resultMap="ResultMapIfaNoticeInfoSql003" statementType="PREPARED">
        SELECT /* @SQLID=SUB0202_00-03#Sql003 */ 
            A.CODE_1 as code1
            , A.NAME as value
        FROM 
            M_CODE A
        <where>            
            A.START_DATE &lt;= TO_CHAR(IFA_DATE_UTIL.IFA_GET_DATE, 'YYYYMMDD')
            AND A.END_DATE &gt;= TO_CHAR(IFA_DATE_UTIL.IFA_GET_DATE, 'YYYYMMDD')
            AND A.CODE_TYPE = '65'
            AND LPAD(A.CODE_1, 3, '0') IN
            <choose>
                <when test="req.limitCode != null and req.limitCode.size() > 0">
                    <foreach collection="req.limitCode" item="item" open="(" close=")" separator=",">
                            #{item}
                    </foreach>                    
                </when>
                <otherwise>
                    ('')
                </otherwise>
            </choose>
        </where>
        ORDER BY
            A.CODE_1 ASC
    </select>
    
    
    
    
</mapper>