	<insert id="insertMedUsers" statementType="PREPARED">
		INSER INTO TB_MED_USERS
			VALUES (
			USER_ID = #{medUsers.userId},
			USER_NM = #{medUsers.userNm},
			PASSWORD = #{medUsers.password},
			PRIV_ID = #{medUsers.privId},
			BRANCH_ID = #{medUsers.branchId},
			BROKER_ID = #{medUsers.brokerId},
			SUB_BROKER_ID = #{medUsers.subBrokerId},
			EMPLOYEE_ID = #{medUsers.employeeId},
			EMPLOYEE_NAME = #{medUsers.employeeName},
			GOVERNOR_FLAG = #{medUsers.governorFlag},
			CREATE_USER = #{medUsers.createUser},
			CREATE_TIME = SYSDATE,
			UPTIMESTAMP_USER = #{medUsers.uptimestampUser},
			MAIL_ADDRESS = #{medUsers.mailAddress}
			)
	</insert>

