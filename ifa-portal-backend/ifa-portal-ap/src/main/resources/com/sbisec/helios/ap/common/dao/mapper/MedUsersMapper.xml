<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.sbisec.helios.ap.common.dao.mapper.MedUsersMapper">

	<resultMap type="com.sbisec.helios.ap.common.model.MedUsers" id="MedUsers">
		<result property="userNm"          column="USER_NM"          typeHandler="com.sbibits.earth.dao.typehandler.StringTypeHandler"/>
		<result property="password"        column="PASSWORD"         typeHandler="com.sbibits.earth.dao.typehandler.StringTypeHandler"/>
		<result property="employeeName"    column="EMPLOYEE_NAME"    typeHandler="com.sbibits.earth.dao.typehandler.StringTypeHandler"/>
		<result property="partnerUserPw"   column="PARTNER_USER_PW"  typeHandler="com.sbibits.earth.dao.typehandler.StringTypeHandler"/>
		<result property="ccsUserPw"       column="CCS_USER_PW"      typeHandler="com.sbibits.earth.dao.typehandler.StringTypeHandler"/>
		<result property="createUser"      column="CREATE_USER"      typeHandler="com.sbibits.earth.dao.typehandler.StringTypeHandler"/>
		<result property="uptimestampUser" column="UPTIMESTAMP_USER" typeHandler="com.sbibits.earth.dao.typehandler.StringTypeHandler"/>
	</resultMap>

	<select id="getMedUsers" resultMap="MedUsers" statementType="PREPARED">
		SELECT
			USER_ID,
			USER_NM,
			PASSWORD,
			LASTPWUPTIME,
			PRIV_ID,
			BRANCH_ID,
			BROKER_ID,
			SUB_BROKER_ID,
			EMPLOYEE_ID,
			EMPLOYEE_NAME,
			GOVERNOR_FLAG,
			LOGIN_STATUS,
			PARTNER_USER_ID,
			PARTNER_USER_PW,
			CCS_USER_ID,
			CCS_USER_PW,
			CREATE_USER,
			CREATE_TIME,
			UPTIMESTAMP_USER,
			UPTIMESTAMP_TIME,
			MAIL_ADDRESS
		FROM
		    TB_MED_USERS
		WHERE
			USER_ID = #{userId}
	</select>
