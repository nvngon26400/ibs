    -->
    <select id="selectIfaDomesticMutualFundOrderCancelConfirmSql00101"
        parameterType="com.sbisec.helios.ap.brokerageMenu.customerMenu.dao.model.IfaDomesticMutualFundOrderCancelConfirmSql001RequestModel"
        resultMap="ResultMapIfaDomesticMutualFundOrderCancelConfirmSql00101" statementType="PREPARED">
        SELECT /* @SQLID=SUB0202_0401-04_1#Sql001 */
            IFA_ORDER_NO
            , IFA_ORDER_SUB_NO
            , BUTEN_CODE
            , ACCOUNT_NUMBER
            , CUSTOMER_ID
