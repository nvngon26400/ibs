        VALUES(
             #{req.ifaOrderNo}              <!-- IFA注文番号 -->
            ,'1'        					<!-- IFA注文サブ番号 -->
            ,#{req.butenCode}               <!-- 部店コード -->
            ,#{req.accountNumber}           <!-- 口座番号 -->
