            , FUNC_CLOSED_TIME
            , JRNISA_TRANSFER_AMOUNT
            , POINT
            , POINT_AFTER
            , BROKER_CODE
            , INTERMEDIARY_EMP_CD
            , CREATE_TIME
            , CREATE_USER
            , UPDATE_TIME
            , UPDATE_USER
            , CCS_SEND_DATE
        FROM 
            CORDYS.JP_TOUSHIN_ORDER
        WHERE 
            ORDER_NUM = #{req.ecOrderNo}
            AND BUTEN_CODE = #{req.butenCode}
            AND ACCEPT_DATE &gt;= #{req.orderDate}
            AND TRIM(TRADE_TYPE) = TRIM(#{req.tradeCd})
            AND IFA_ORDER_SUB_NO = (
            SELECT
                MAX(IFA_ORDER_SUB_NO) AS MAX_IFA_ORDER_SUB_NO
            FROM CORDYS.JP_TOUSHIN_ORDER
            WHERE ORDER_NUM = #{req.ecOrderNo}
                AND BUTEN_CODE = #{req.butenCode}
                AND ACCEPT_DATE &gt;= #{req.orderDate}
                AND TRIM(TRADE_TYPE) = TRIM(#{req.tradeCd})
          )
    </select>
    <!-- 
        SQLID：Sql001
        SQL名：シーケンスオブジェクトの取得
        SQLタイプ：select
    -->
    <select id="selectIfaDomesticMutualFundOrderCancelConfirmSql00102"
        parameterType="com.sbisec.helios.ap.brokerageMenu.customerMenu.dao.model.IfaDomesticMutualFundOrderCancelConfirmSql001RequestModel"
        resultMap="ResultMapIfaDomesticMutualFundOrderCancelConfirmSql00102" statementType="PREPARED">
        SELECT  /* @SQLID=SUB0202_0401-04_1#Sql001 */
              CONCAT(TO_CHAR(IFA_DATE_UTIL.IFA_GET_DATE, 'YYYYMMDD'),
              LPAD(CORDYS.SEQ_JP_TOUSHIN_ORDER.NEXTVAL, 10, '0')) AS IFA_ORDER_NO
        FROM
            DUAL
    </select>

