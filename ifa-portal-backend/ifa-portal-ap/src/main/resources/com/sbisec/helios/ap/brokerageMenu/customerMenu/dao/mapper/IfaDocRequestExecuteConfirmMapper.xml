                ,EDABAN
                ,BUTEN_CODE
                ,ACCOUNT_NUMBER
                ,KOKYAKU_ID
                ,SHORUI_CD
                ,SHORUIMEI
                ,SHORUI_BUNRUI_CD
                ,SHORUI_BUNRUI_MEI
                ,RIYUU_CD
                ,HASSOU_STS
                ,USER_ID
                ,TORIKESHI_KBN
                ,TORIKESHI_USER_ID
                ,BUSUU
                ,OPTION_1
                ,SENTAKU_MEI1
                ,OPTION_2
                ,SENTAKU_MEI2
                ,OPTION_3
                ,SENTAKU_MEI3
                ,TXT_1
                ,TXT_NAIYOU_1
                ,TXT_2
                ,TXT_NAIYOU_2
                ,TXT_3
                ,TXT_NAIYOU_3
                ,TXT_4
                ,TXT_NAIYOU_4
                ,TXT_5
                ,TXT_NAIYOU_5
                ,NAIYOU_CAPTION
                ,NAIYOU
                ,BIKOU_CAPTION
                ,BIKOU
                ,LOGIN_PW
                ,TORIHIKI_PW
                ,YUUSOU_SHUBETSU
                ,SHORUI_HASSOU_NO
                ,SHORI_KAISUU
                ,MOKURONMISHO_NO
                ,SHORUI_SEIKYUU_NICHIJI
                ,STS_SENI_NICHIJI
                ,TOUROKU_NICHIJI
                ,HENKOU_NICHIJI
                ,SAKUJO_NICHIJI
                ,SAKUJO_FLG
                ,SOKUJI_KBN
                ,ZENKAI_TYOUKANTAN_FLG
