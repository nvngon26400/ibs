                #{req.shoruiSeikyuuNo}                              <!-- トランザクションID -->
                ,#{req.edaban}                             <!-- 枝番 -->
                ,#{req.butenCode}                          <!-- 部店CD -->
                ,#{req.accountNumber}                      <!-- 口座番号 -->
                ,#{req.kokyakuId}                          <!-- 顧客ID -->
                ,#{req.shoruiCd}                           <!-- 書類コード -->
                ,#{req.shoruimei}                          <!-- 書類名 -->
                ,#{req.shoruiBunruiCd}                     <!-- 書類分類コード -->
                ,#{req.shoruiBunruiMei}                    <!-- 書類分類名 -->
                ,null                                      <!-- 理由コード -->
                ,#{req.hassouSts}                          <!-- 発送ステータス -->
                ,#{req.userId}                             <!-- ユーザーID -->
                ,#{req.torikeshiKbn}                       <!-- 取消区分 -->
                ,null                                      <!-- 取消ユーザーID -->
                ,#{req.busuu}                              <!-- 部数 -->
                ,#{req.option1}                            <!-- オプション1(名前) -->
                ,#{req.sentakuMei1}                        <!-- オプション1(選択) -->
                ,#{req.option2}                            <!-- オプション2(名前) -->
                ,#{req.sentakuMei2}                        <!-- オプション2(選択) -->
                ,#{req.option3}                            <!-- オプション3(名前) -->
                ,#{req.sentakuMei3}                        <!-- オプション3(選択) -->
                ,#{req.txt1}                               <!-- テキスト1(名前) -->
                ,#{req.txtNaiyou1}                         <!-- テキスト1(入力) -->
                ,#{req.txt2}                               <!-- テキスト2(名前) -->
                ,#{req.txtNaiyou2}                         <!-- テキスト2(入力) -->
                ,#{req.txt3}                               <!-- テキスト3(名前) -->
                ,#{req.txtNaiyou3}                         <!-- テキスト3(入力) -->
                ,#{req.txt4}                               <!-- テキスト4(名前) -->
                ,#{req.txtNaiyou4}                         <!-- テキスト4(入力) -->
                ,#{req.txt5}                               <!-- テキスト5(名前) -->
                ,#{req.txtNaiyou5}                         <!-- テキスト5(入力) -->
                ,#{req.naiyouCaption}                      <!-- 内容キャプション -->
                ,#{req.naiyou}                             <!-- 内容(入力) -->
                ,#{req.bikouCaption}                       <!-- 備考キャプション -->
                ,#{req.bikou}                              <!-- 備考(入力) -->
                ,null                                      <!-- 更新後ログインPW -->
                ,null                                      <!-- 更新後取引PW -->
                ,null                                      <!-- 郵送種別 -->
                ,null                                      <!-- 書類発送NO -->
                ,#{req.shoriKaisuu}                        <!-- 処理回数 -->
                ,null                                      <!-- 目論見書No -->
                ,SYSDATE                                   <!-- 書類請求日時 -->
                ,SYSDATE                                   <!-- ステータス遷移日時 -->
                ,SYSDATE                                   <!-- 登録日時 -->
                ,SYSDATE                                   <!-- 変更日時 -->
                ,null                                      <!-- 削除日時 -->
                ,#{req.sakujoFlg}                          <!-- 削除フラグ -->
                ,null                                      <!-- 即時区分 -->
                ,#{req.zenkaiTyoukantanFlg}                <!-- 前回超かんたんフラグ -->
                ,null                                      <!-- CCS送付日 -->
