        INSERT /* @SQLID=SUB0202_0704-02_1#Sql005 */ INTO TB_BM_DELIVERY_IFA
            (
                BM_DELIVERY_NO
                ,SHUBETSU
                ,BUTEN_CODE
                ,ACCOUNT_NUMBER
                ,KOKYAKU_ID
                ,SHORUI_CD
                ,SHORUIMEI
                ,SHORUI_BUNRUI_CD
                ,SHORUI_BUNRUI_MEI
                ,MEIGARA_CD
                ,MEIGARA_MEI
                ,KYOKAI_CD
                ,BM_DELIVERY_TIME
                ,BM_DELIVERY_TIME_SCHEDULE
                ,USER_ID
                ,CCS_USER_ID
                ,BROKER_CODE
                ,INTERMEDIARY_EMP_CD
                ,STATUS
                ,CREATE_TIME
                ,CREATE_USER
                ,UPDATE_TIME
                ,UPDATE_USER
            )
            VALUES
            (
                #{req.bmDeliveryNo}                        <!-- BM交付番号 -->
                ,#{req.shubetsu}                           <!-- 種別 -->
                ,#{req.butenCode}                          <!-- 部店コード -->
                ,#{req.accountNumber}                      <!-- 口座番号 -->
                ,#{req.kokyakuId}                          <!-- 顧客ID -->
                ,#{req.shoruiCd}                           <!-- 書類コード -->
                ,#{req.shoruimei}                          <!-- 書類名 -->
                ,#{req.shoruiBunruiCd}                     <!-- 書類分類コード -->
                ,#{req.shoruiBunruiMei}                    <!-- 書類分類名 -->
                ,#{req.meigaraCd}                          <!-- 銘柄コード -->
                ,#{req.meigaraMei}                         <!-- 銘柄名 -->
                ,#{req.kyokaiCd}                           <!-- 協会コード -->
                ,#{req.bmDeliveryTime}                      <!-- BM交付日時 -->
                ,#{req.bmDeliveryTimeSchedule}             <!-- BM配信予定日時 -->
                ,#{req.userId}                             <!-- ユーザーID -->
                ,#{req.ccsUserId}                          <!-- CCSログイン用ID -->
                ,#{req.brokerCode}                         <!-- 仲介業者コード -->
                ,#{req.intermediaryEmpCd}                  <!-- 仲介業者営業員コード -->
                ,#{req.status}                             <!-- ステータス -->
                ,SYSDATE                                   <!-- 作成日時 -->
                ,#{req.userId}                             <!-- 作成者 -->
                ,SYSDATE                                   <!-- 更新日時 -->
                ,#{req.userId}                             <!-- 更新者 -->
            )
    </insert>

    <!-- 
        SQLID：selectSeqTbBmDeliveryIfa
        SQL名：SEQUENCE(トランザクションID)を取得する
        SQLタイプ：select
    -->
    <select id="selectSeqTbBmDeliveryIfa" resultType="String" statementType="PREPARED">
        SELECT LPAD(SEQ_TB_BM_DELIVERY_IFA.NEXTVAL, 10, '0')        <!-- トランザクションID -->
        FROM DUAL
    </select>
</mapper>