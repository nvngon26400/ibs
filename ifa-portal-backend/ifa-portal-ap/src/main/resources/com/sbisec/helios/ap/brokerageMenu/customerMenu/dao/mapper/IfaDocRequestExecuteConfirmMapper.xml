    </insert>

    <!-- 
        SQLID：selectSeqTbRequestPapersIfa
        SQL名：SEQUENCE(トランザクションID)を取得する
        SQLタイプ：select
    -->
    <select id="selectSeqTbRequestPapersIfa" resultType="String" statementType="PREPARED">
        SELECT SEQ_TB_REQUEST_PAPERS_IFA.NEXTVAL        <!-- トランザクションID -->
        FROM DUAL
    </select>

        <!-- 
        SQLID：Sql002
        SQL名：未閲読目論見書件数取得
        SQLタイプ：select
    -->
    <select id="selectIfaDocRequestExecuteConfirmSql002" resultMap="ResultMapDocRequestExecuteConfirmSql002" statementType="PREPARED">
        SELECT /* @SQLID=SUB0202_0704-02_1#Sql002 */
            COUNT(*) AS DATA_NUM                                                                      <!-- データ件数 -->
        FROM 
        (
            SELECT
                A.DM_DOCUMENT_ID
                ,A.DM_VERSION_NUMBER
                ,A.DM_MEIGARA_CODE
            FROM ETRADE.DOCUMENT_MANAGEMENT@CORDYS_ET10.WORLD A
            INNER JOIN ETRADE.DOCUMENT_PROFILE@CORDYS_ET10.WORLD B
            ON B.DP_PRODUCT_ID = A.DM_PRODUCT_ID
            AND B.DP_MEIGARA_CODE = A.DM_MEIGARA_CODE
            AND B.DP_DOCUMENT_ID = A.DM_DOCUMENT_ID
            AND B.DP_VERSION_NUMBER = A.DM_VERSION_NUMBER
            AND B.DP_ITEM_NAME = 'DOCUMENT_FOR_COMPANY'
            WHERE A.DM_PRODUCT_ID = '51'
            AND A.DM_MEIGARA_CODE = #{req.fundCode}                                                <!-- 銘柄コード -->
            AND TO_CHAR(SYSDATE, 'YYYYMMDD') BETWEEN A.DM_ACTIVE_TERM_FROM AND A.DM_ACTIVE_TERM_TO
            AND A.DM_SERVICE_LIMIT &gt;= TO_CHAR(SYSDATE, 'YYYYMMDD')
            <if test='req.corporationType != "1"'>
                AND B.DP_ITEM_VALUE = '0'
            </if>
        ) D
        LEFT JOIN ETRADE.MMF_EDELIV_AGREEMENT@CORDYS_ET10.WORLD C
        ON D.DM_MEIGARA_CODE = C.MEA_PRODUCT_CODE
        AND D.DM_DOCUMENT_ID = C.MEA_DOCUMENT_ID
        AND D.DM_VERSION_NUMBER = C.MEA_VERSION_NUMBER
        AND C.MEA_BUTEN_CODE = #{req.butenCode}
        AND C.MEA_ACCOUNT_NUMBER = #{req.accountNumber}
        WHERE (C.MEA_EDELIV_AGREEMENT IS NULL OR C.MEA_EDELIV_AGREEMENT &lt;&gt; '1')
    </select>

    <!-- 
        SQLID：Sql003
        SQL名：IFA用BMスケジュール情報取得
        SQLタイプ：select
    -->
    <select id="selectIfaDocRequestExecuteConfirmSql003" resultMap="ResultMapDocRequestExecuteConfirmSql003" statementType="PREPARED">
        SELECT /* @SQLID=SUB0202_0704-02_1#Sql003 */
            A.DELIVERY_SCHEDULE_TIME AS DELIVERY_SCHEDULE_TIME                                            <!-- 配信予定時刻 -->
            ,A.NEXT_DAY_FLG AS NEXT_DAY_FLG                                                               <!-- 翌日フラグ -->
        FROM TB_BM_SCHEDULE_IFA A
        WHERE A.ACCEPT_TIME_FROM &lt;= #{req.sysTimeHHmm}                                                    <!-- 時刻 -->
        AND A.ACCEPT_TIME_TO &gt;= #{req.sysTimeHHmm}                                                        <!-- 時刻 -->
    </select>

        <!-- 
        SQLID：Sql004
        SQL名：1回目配信予定時刻取得
        SQLタイプ：select
    -->
    <select id="selectIfaDocRequestExecuteConfirmSql004" resultMap="ResultMapDocRequestExecuteConfirmSql004" statementType="PREPARED">
        SELECT /* @SQLID=SUB0202_0704-02_1#Sql004 */
            A.DELIVERY_SCHEDULE_TIME AS DELIVERY_SCHEDULE_TIME                                            <!-- 配信予定時刻 -->
        FROM TB_BM_SCHEDULE_IFA A
        WHERE A.SCHEDULE_NO = '1'                                                                         <!-- スケジュール番号 -->
    </select>

    <!--
        SQLID：Sql005
        SQL名：BM交付登録
        SQLタイプ：select
    -->
