     <resultMap id="ResultMapDocRequestExecuteConfirmSql003" type="com.sbisec.helios.ap.brokerageMenu.customerMenu.dao.model.IfaDocRequestExecuteConfirmSql003ResponseModel"/>
     <resultMap id="ResultMapDocRequestExecuteConfirmSql004" type="com.sbisec.helios.ap.brokerageMenu.customerMenu.dao.model.IfaDocRequestExecuteConfirmSql004ResponseModel"/>
    <!-- 
        SQLID：Sql001
        SQL名：書類請求確認
        SQLタイプ：insert
    -->
    <insert id="insertIfaDocRequestExecuteConfirmSql001" statementType="PREPARED">
        INSERT /* @SQLID=SUB0202_0704-02_1#Sql001 */ INTO TB_REQUEST_PAPERS_IFA
