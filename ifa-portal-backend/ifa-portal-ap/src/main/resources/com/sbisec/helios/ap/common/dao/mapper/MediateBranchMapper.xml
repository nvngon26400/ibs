			BROKER_CODE,
			BRANCH_NAME
		FROM MEDIATE_BRANCH
		WHERE
			BROKER_BRANCH_CODE = #{brokerBranchCode}
		ORDER BY BROKER_CODE
	</select>

	<select id="getBrokerCount" resultType="java.lang.Integer" statementType="PREPARED">
		SELECT
			COUNT(1) AS COUNT
		FROM
			MEDIATE_BRANCH
		WHERE
			1=1
		<if test="brokerCode != null">
			AND BROKER_CODE = #{brokerCode}
		</if>
		<if test="brokerBranchCode != null">
			AND BROKER_BRANCH_CODE = #{brokerBranchCode}
		</if>
	</select>
	 -->
</mapper>
