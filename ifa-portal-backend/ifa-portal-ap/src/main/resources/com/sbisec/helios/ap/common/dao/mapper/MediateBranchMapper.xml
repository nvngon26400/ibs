<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.sbisec.helios.ap.common.dao.mapper.MediateBranchMapper">

	<resultMap type="com.sbisec.helios.ap.common.model.MediateBranch" id="MediateBranch">
		<result property="branchName"       column="BRANCH_NAME"        typeHandler="com.sbibits.earth.dao.typehandler.StringTypeHandler"/>
	</resultMap>
<!-- 
	<resultMap type="com.sbibits.horus.ap.counter.model.OfferInfoModel" id="GetOfferInfoList"></resultMap>
 -->
	<select id="getMediateBranch" resultMap="MediateBranch" statementType="PREPARED">
		SELECT
			BROKER_CODE,
			BROKER_BRANCH_CODE,
			BROKER_BRANCH_KIND,
			BRANCH_NAME
		FROM
			MEDIATE_BRANCH
		WHERE
			BROKER_CODE = #{brokerCode}
		AND BROKER_BRANCH_CODE = #{brokerBranchCode}
	</select>
