                            <if test="index % 1000 == 0 and index != 0">
                                ) OR A.BROKER_CODE IN (
                            </if>
                            <if test="index % 1000 != 0">
                                ,
                            </if>
                                #{brokerCharge.brokerCode}
                        </foreach>
                        )
                    </when>
            </choose>
        </where>
    </select>
    
    <!-- 
        SQLID：Sql003
        SQL名：仲介業者期初年月取得
        SQLタイプ：select
    -->
    <select id="selectIfaBrokerCodeClosingMonthLoginSql003" resultMap="ResultMapIfaBrokerCodeClosingMonthLoginSql003" statementType="PREPARED">
        SELECT /* @SQLID=SUB0406-01_1#Sql003 */
            C.START_YM AS BeginYearMonth
        FROM
            CORDYS.MEDIATE_BUSINESS_REPORT C
        <where>
            <if test="req.brokerCode != null and req.brokerCode != '' ">
               AND C.BROKER_CODE = #{req.brokerCode} 
            </if> 
            <choose>
                <when test="req.brokerChargeList != null and !req.brokerChargeList.isEmpty()">
                        AND (C.BROKER_CODE IN
                        <foreach item="brokerCharge" index="index" collection="req.brokerChargeList" open="(" close=")">
                            <if test="index % 1000 == 0 and index != 0">
                                ) OR C.BROKER_CODE IN (
                            </if>
                            <if test="index % 1000 != 0">
                                ,
                            </if>
                                #{brokerCharge.brokerCode}
                        </foreach>
                        )
                    </when>
            </choose>
            AND C.CLOSING_KBN = '0'
        </where>
    </select>

</mapper>