    <select id="selectIfaBrokerCodeClosingMonthLoginSql002" resultMap="ResultMapIfaBrokerCodeClosingMonthLoginSql002" statementType="PREPARED">
        SELECT /* @SQLID=SUB0406-01_1#Sql002 */
            A.CLOSING_MONTH AS closingMonth
        FROM
            CORDYS.M_MEDIATE_CLOSING_MONTH A
        <where>
            <if test="req.brokerCode != null and req.brokerCode != '' ">
               AND A.BROKER_CODE = #{req.brokerCode} 
