    -->
    <select id="selectIfaDocRequestInputSql006" resultMap="ResultMapDocRequestInputSql006" statementType="PREPARED">
        SELECT /* @SQLID=SUB0202_0704-01#Sql006 */
            M_F_CODE AS FUND_CODE                                                                           <!-- 協会コード -->
            ,M_F_NAME AS FUND_NAME                                                                          <!-- 投信銘柄名 -->
            ,M_F_MD_BUY_KUBUN AS FUND_MD_BUY_KUBUN                                                          <!-- 購入可否判定区分 -->
        FROM ETRADE.FUND@CORDYS_ET10.WORLD
        WHERE M_F_NRICODE = #{req.fundNricode}                                                             <!-- NRIコード -->
        AND M_F_TYPE IN ('1', '2')                                                                         <!-- ファンドタイプ -->
        AND M_F_DELFLG = '0'                                                                               <!-- 削除フラグ -->
        AND M_F_ET_START_DATE &lt;= TO_CHAR(SYSDATE, 'YYYYMMDD')                                           <!-- ET取扱開始日 -->
    </select>

