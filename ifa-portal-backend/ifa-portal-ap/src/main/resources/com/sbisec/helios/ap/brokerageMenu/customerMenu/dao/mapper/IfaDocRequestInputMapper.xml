    <!-- 
        SQLID：Sql001
        SQL名：書類分類リストを取得する
        SQLタイプ：select
    -->
    <select id="selectIfaDocRequestInputSql001" resultMap="ResultMapDocRequestInputSql001" statementType="PREPARED">
        SELECT /* @SQLID=SUB0202_0704-01#Sql001 */
            SHORUI_CD AS BUNRUI_CD                                                                      <!-- 書類コード -->
            ,SHORUIMEI AS BUNRUIMEI                                                                     <!-- 書類名 -->
        FROM TB_PAPER_MASTER_IFA
        WHERE SHORUI_KBN = #{req.shoruiKbn}                                                             <!-- 書類区分 -->
        AND SAKUJO_FLG = #{req.sakujoFlg}                                                               <!-- 削除フラグ -->
        ORDER BY SORT_NO
    </select>

    <!-- 
        SQLID：Sql002
        SQL名：書類請求一覧表示対象データを取得する
        SQLタイプ：select
    -->
    <select id="selectIfaDocRequestInputSql002" resultMap="ResultMapDocRequestInputSql002" statementType="PREPARED">
        SELECT /* @SQLID=SUB0202_0704-01#Sql002 */
            ABC.SHORUI_SEIKYUU_NO                                                                         <!-- 書類請求NO -->
            ,ABC.EDABAN                                                                                   <!-- 枝番 -->
            ,ABC.BM_DELIVERY_NO                                                                           <!-- BM交付番号 -->
            ,TO_CHAR(ABC.SHORUI_SEIKYUU_NICHIJI,'YYYY/MM/DD HH24:MI') AS SHORUI_SEIKYUU_NICHIJI           <!-- 書類請求日時 -->
            ,ABC.SHORUI_BUNRUI_MEI                                                                        <!-- 書類分類名 -->
            ,ABC.SHORUIMEI                                                                                <!-- 書類名 -->
            ,ABC.BUSUU                                                                                    <!-- 部数 -->
            ,ABC.TORIKESHI_KBN                                                                            <!-- 取消区分 -->
            ,ABC.USER_NM                                                                                  <!-- ユーザー名 -->
        FROM(
            SELECT
                A.SHORUI_SEIKYUU_NO AS SHORUI_SEIKYUU_NO
                ,A.EDABAN AS EDABAN
                ,NULL AS BM_DELIVERY_NO
                ,A.SHORUI_SEIKYUU_NICHIJI
                ,A.SHORUI_BUNRUI_MEI AS SHORUI_BUNRUI_MEI
                ,A.SHORUIMEI AS SHORUIMEI
                ,A.BUSUU AS BUSUU
                ,B.USER_NM AS USER_NM
                ,TO_CHAR(A.TORIKESHI_KBN) AS TORIKESHI_KBN
            FROM TB_REQUEST_PAPERS_IFA A
            INNER JOIN TB_MED_USERS B
            ON A.USER_ID = B.USER_ID
            WHERE A.BUTEN_CODE = #{req.butenCode}                                                            <!-- 部店コード -->
            AND A.ACCOUNT_NUMBER = #{req.accountNumber}                                                      <!-- 口座番号 -->
            AND A.SHORUI_SEIKYUU_NICHIJI &gt;= TO_DATE(TO_CHAR(SYSDATE, 'YYYYMMDD'), 'YYYYMMDD') - 7         <!-- 書類請求日時 -->
            UNION ALL
            SELECT
                NULL AS SHORUI_SEIKYUU_NO
                ,NULL AS EDABAN
                ,C.BM_DELIVERY_NO AS BM_DELIVERY_NO
                ,C.BM_DELIVERY_TIME AS SHORUI_SEIKYUU_NICHIJI
                ,C.SHORUI_BUNRUI_MEI AS SHORUI_BUNRUI_MEI
                ,C.SHORUIMEI AS SHORUIMEI
                ,NULL AS BUSUU
                ,B.USER_NM AS USER_NM
                ,C.STATUS AS TORIKESHI_KBN
            FROM CORDYS.TB_BM_DELIVERY_IFA C
            INNER JOIN TB_MED_USERS B
            ON C.USER_ID = B.USER_ID
            WHERE C.BUTEN_CODE = #{req.butenCode}                                                            <!-- 部店コード -->
            AND C.ACCOUNT_NUMBER = #{req.accountNumber}                                                      <!-- 口座番号 -->
            AND C.BM_DELIVERY_TIME &gt;= TO_DATE(TO_CHAR(SYSDATE, 'YYYYMMDD'), 'YYYYMMDD') - 7               <!-- BM交付日時 -->
        ) ABC
        ORDER BY ABC.SHORUI_SEIKYUU_NICHIJI DESC
    </select>

