            COUNT(*) AS BROKER_NUM
        FROM  M_JOINT_BROKER A
        WHERE A.BROKER_CODE = #{req.brokerCode}                                                     <!-- 仲介業者コード -->
        AND A.DELETE_FLG = '0'                                                                      <!-- 削除フラグ -->
        AND A.CONTRACT_STATUS = '1'                                                                 <!-- 契約状態1:契約-->
    </select>
    <!-- 
        SQLID：Sql009
        SQL名：交付区分の表示設定を取得する
        SQLタイプ：select
    -->
    <select id="selectIfaDocRequestInputSql009" resultMap="ResultMapDocRequestInputSql009" statementType="PREPARED">
        SELECT /* @SQLID=SUB0202_0704-01#Sql009 */
            HASSOU_SHUBETSU AS HASSOU_STS                                                            <!-- 発送ステータス表示種別 -->
        FROM TB_PAPER_HASSOU_DISP_IFA
        WHERE BUNRUI_CD = #{req.shoruiBunruiCd}                                                      <!-- 分類コード -->
        AND SHORUI_CD = #{req.shoruiCd}                                                              <!-- 書類コード -->
        AND BROKER_SHUBETSU = #{req.brokerShubetsu}                                                  <!-- 仲介業者種別 -->
    </select>

    <!-- 
        SQLID：Sql010
        SQL名：未閲読目論見書件数取得
        SQLタイプ：select
    -->
    <select id="selectIfaDocRequestInputSql010" resultMap="ResultMapDocRequestInputSql010" statementType="PREPARED">
        SELECT /* @SQLID=SUB0202_0704-01#Sql010 */
            COUNT(*) AS DATA_NUM                                                                      <!-- データ件数 -->
        FROM 
        (
            SELECT
                A.DM_DOCUMENT_ID
                ,A.DM_VERSION_NUMBER
                ,A.DM_MEIGARA_CODE
            FROM ETRADE.DOCUMENT_MANAGEMENT@CORDYS_ET10.WORLD A
            INNER JOIN ETRADE.DOCUMENT_PROFILE@CORDYS_ET10.WORLD B
            ON B.DP_PRODUCT_ID = A.DM_PRODUCT_ID
            AND B.DP_MEIGARA_CODE = A.DM_MEIGARA_CODE
            AND B.DP_DOCUMENT_ID = A.DM_DOCUMENT_ID
            AND B.DP_VERSION_NUMBER = A.DM_VERSION_NUMBER
            AND B.DP_ITEM_NAME = 'DOCUMENT_FOR_COMPANY'
            WHERE A.DM_PRODUCT_ID = '51'
            AND A.DM_MEIGARA_CODE = #{req.fundCode}                                                <!-- 銘柄コード -->
            AND TO_CHAR(SYSDATE, 'YYYYMMDD') BETWEEN A.DM_ACTIVE_TERM_FROM AND A.DM_ACTIVE_TERM_TO
            AND A.DM_SERVICE_LIMIT &gt;= TO_CHAR(SYSDATE, 'YYYYMMDD')
            <if test='req.corporationType != "1"'>
                AND B.DP_ITEM_VALUE = '0'
            </if>
        ) D
        LEFT JOIN ETRADE.MMF_EDELIV_AGREEMENT@CORDYS_ET10.WORLD C
        ON D.DM_MEIGARA_CODE = C.MEA_PRODUCT_CODE
        AND D.DM_DOCUMENT_ID = C.MEA_DOCUMENT_ID
        AND D.DM_VERSION_NUMBER = C.MEA_VERSION_NUMBER
        AND C.MEA_BUTEN_CODE = #{req.butenCode}
        AND C.MEA_ACCOUNT_NUMBER = #{req.accountNumber}
        WHERE (C.MEA_EDELIV_AGREEMENT IS NULL OR C.MEA_EDELIV_AGREEMENT &lt;&gt; '1')
    </select>

        <!-- 
        SQLID：Sql011
        SQL名：外貨建MMF銘柄名取得
        SQLタイプ：select
    -->
    <select id="selectIfaDocRequestInputSql011" resultMap="ResultMapDocRequestInputSql011" statementType="PREPARED">
        SELECT /* @SQLID=SUB0202_0704-01#Sql011 */
            MPM_PRODUCT_NAME AS MPM_PRODUCT_NAME                                                     <!-- 銘柄名 -->
        FROM ETRADE.MMF_PRODUCT_MASTER@CORDYS_ET10.WORLD B
        WHERE B.MPM_PRODUCT_CODE = #{req.fundCode}                                                   <!-- 銘柄コード -->
    </select>

        <!-- 
        SQLID：Sql012
        SQL名：BM交付データ取得
        SQLタイプ：select
    -->
    <select id="selectIfaDocRequestInputSql012" resultMap="ResultMapDocRequestInputSql012" statementType="PREPARED">
        SELECT /* @SQLID=SUB0202_0704-01#Sql012 */
            C.SHORUI_BUNRUI_MEI AS SHORUI_BUNRUI_MEI                                                  <!-- 書類分類名 -->
            ,C.SHORUIMEI AS SHORUIMEI                                                                 <!-- 書類名 -->
            ,C.MEIGARA_CD AS MEIGARA_CD                                                               <!-- 銘柄コード -->
            ,C.MEIGARA_MEI AS MEIGARA_MEI                                                             <!-- 銘柄名 -->
            ,C.BM_DELIVERY_TIME_SCHEDULE AS BM_DELIVERY_TIME_SCHEDULE                                 <!-- BM配信予定日時 -->
            ,B.USER_NM AS USER_NM                                                                     <!-- ユーザー名 -->
            ,C.SHUBETSU AS SHUBETSU                                                                   <!-- 種別 -->
            ,C.BM_DELIVERY_NO AS BM_DELIVERY_NO                                                       <!-- BM交付番号 -->
        FROM TB_BM_DELIVERY_IFA C
        INNER JOIN TB_MED_USERS B
        ON C.USER_ID = B.USER_ID
        WHERE C.BM_DELIVERY_NO = #{req.bmDeliveryNo}                                                  <!-- BM交付番号 -->
    </select>

</mapper>