            ,A.OPTION_1                                                                                  <!-- オプション1(名前) -->
            ,A.SENTAKU_MEI1                                                                              <!-- オプション1(選択) -->
            ,A.OPTION_2                                                                                  <!-- オプション2(名前) -->
            ,A.SENTAKU_MEI2                                                                              <!-- オプション2(選択) -->
            ,A.OPTION_3                                                                                  <!-- オプション3(名前) -->
            ,A.SENTAKU_MEI3                                                                              <!-- オプション3(選択) -->
            ,A.TXT_1                                                                                     <!-- テキスト1(名前) -->
