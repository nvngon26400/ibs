            ,null                            <!-- 建玉余力（数値(整数)） -->
            ,null                            <!-- 注文後の建玉余力（数値(整数)） -->
            ,null                            <!-- 維持率 -->
            ,null                            <!-- 注文後維持率（数値(整数)） -->
            ,null                            <!-- 適用金利（数値(小数)） -->
