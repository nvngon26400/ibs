    <!-- 
        SQLID：Sql002
        SQL名：発注後の注文更新
        SQLタイプ：update
    -->
    <update id="updateIfaMarginNewOrderConfirmSql002" statementType="PREPARED">
        UPDATE /* @SQLID=SUB0202_0212-01_2#Sql001 */ T_JP_ORDER
        SET
            SHUBETU = #{req.shubetu}
            ,CODE = #{req.code}
            ,MESSAGE = #{req.errMessage}
            ,UPDATE_TIME = IFA_DATE_UTIL.IFA_GET_DATE
            ,UPDATE_USER = #{req.updateUser}
            ,ACCEPT_DATE = #{req.orderDate}
            <if test='req.isApiError == "0"' >
                ,ORDER_TYPE = #{req.securityType}
                ,ORDER_NUM = #{req.ecOrderNo}
                ,ACCEPT_TIME = #{req.acceptTime}
                ,ESTIMATE_PRICE = #{req.estimatePrice}
                ,AMOUNT = #{req.amount}
                ,COMMISSION = #{req.commission}
                ,CONSUMPTION_TAX = #{req.consumptionTax}
                ,CAPITAL_GAIN_TAX = #{req.capitalGainTax}
                ,NET_AMOUNT = #{req.netAmount}
                ,COST = #{req.cost}
                ,TRADE_DATE = #{req.contractDate}
                ,SETTLEMENT_DATE = #{req.deliveryDate}
                ,ACCEPT_LIMIT = #{req.acceptLimit}
                ,DONE_ACCEPT_LIMIT = #{req.doneAcceptLimit}
                ,COM_ID_R = #{req.comIdR}
                ,AC_POSITION = #{req.acPosition}
                ,AC_POSITION_AFTER = #{req.acPositionAfter}
                ,AC_BALANCE = #{req.acBalance}
                ,AC_BALANCE_AFTER = #{req.acBalanceAfter}
                ,ORDERED_MARKET = #{req.orderedMarket}
                ,TRADE_DEFICIT_AMOUNT = #{req.tradeDeficitAmount}
                ,ISA_BUY_LIMIT = #{req.isaBuyLimit}
                ,JRNISA_TRANSFER_AMOUNT = #{req.jrnisaTransferAmount}
                ,SOR_LINK_KBN = #{req.sorLinkKbn}
                ,UNCLOSED_QUANTITY = #{req.unclosedQuantity}
                ,UNCLOSED_QUANTITY_AFTER = #{req.unclosedQuantityAfter}
                ,MARGIN_CAPABILITY = #{req.marginCapability}
                ,MARGIN_CAPABILITY_AFTER = #{req.marginCapabilityAfter}
                ,ACTUAL_GRNT_RATE = #{req.domesticMarginActualGrntRate}
                ,ACTUAL_GRNT_RATE_AFTER = #{req.actualGrntRateAfter}
                ,APP_INTEREST_RATES = #{req.applicableInterestRate}
                ,APP_LENDING_STOCK = #{req.applicableStockLendingFees}
                ,PREMIUM = #{req.premium}
                ,TPOINT = null
                ,TPOINT_AFTER = null
            </if>
         WHERE 
            IFA_ORDER_NO = #{req.ifaOrderNo}                <!-- IFA注文番号 -->
            AND IFA_ORDER_SUB_NO = '1'    <!-- IFA注文サブ番号 -->

    </update>

    <!-- 
        SQLID：Sql002
        SQL名：発注後の注文更新(発注がエラーの場合(API応答なし))
        SQLタイプ：update
    -->
    <update id="updateIfaMarginNewOrderConfirmSql002b" statementType="PREPARED">
        UPDATE /* @SQLID=SUB0202_0212-01_2#Sql001 */ T_JP_ORDER
        SET
            UPDATE_TIME = IFA_DATE_UTIL.IFA_GET_DATE
            ,UPDATE_USER = #{req.updateUser}
            ,ACCEPT_DATE = IFA_DATE_UTIL.IFA_GET_SDATE('YYYYMMDD')
         WHERE 
            IFA_ORDER_NO = #{req.ifaOrderNo}                <!-- IFA注文番号 -->
            AND IFA_ORDER_SUB_NO = '1'                      <!-- IFA注文サブ番号 -->

    </update>

    <select id="selectIfaMarginNewOrderConfirmSql003" resultType="String" statementType="PREPARED">
        SELECT     
            TO_CHAR(IFA_DATE_UTIL.IFA_GET_DATE, 'YYYYMMDD') || LPAD(SEQ_T_JP_ORDER.NEXTVAL, 10, '0') AS IFA_ORDER_NO
        FROM    
            DUAL

    </select>

</mapper>