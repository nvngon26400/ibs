<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<!-- 
    画面ID：SUB0202_0106-03
    画面名：接触履歴入力
-->
<mapper namespace="com.sbisec.helios.ap.brokerageMenu.customerMenu.dao.mapper.IfaContactInputMapper">
    <!-- 
         SQLID:Sql001
         SQL名:問合せカテゴリリスト（大）取得
         SQLタイプ:select
    -->
    <resultMap id="ResultMapIfaContactInputSql001" 
        type="com.sbisec.helios.ap.brokerageMenu.customerMenu.dao.model.IfaContactInputSql001ResponseModel" >
        <result property="toiawaseMei" column="TOIAWASE_MEI" typeHandler="com.sbibits.earth.dao.typehandler.StringTypeHandler"/>
    </resultMap>
    <select id="selectIfaContactInputSql001" resultMap="ResultMapIfaContactInputSql001" statementType="PREPARED">
        SELECT /* @SQLID=SUB0202_0106-03#SQL001 */
             TOIAWASE_CD                                                            <!-- 問合せカテゴリコード -->
            ,TOIAWASE_MEI                                                           <!-- カテゴリー名称 -->
        FROM
            CORDYS.TB_QUESTION_MASTER_IFA                                           <!-- 【IFA問合せマスタ】 -->
        WHERE
            TOIAWASE_KBN = #{req.toiawaseKbn}                                       <!-- 問合せ区分 -->
            AND IFA_SENYOU_FLG = #{req.ifaSenyouFlg}                                <!-- IFA専用フラグ -->
            AND SAKUJO_FLG = #{req.sakujoFlg}                                       <!-- 削除フラグ -->
        ORDER BY
            SORT_NO
    </select>

    <!-- 
         SQLID:Sql002
         SQL名:問合せ情報取得
         SQLタイプ:select
    -->
    <resultMap id="ResultMapIfaContactInputSql002" 
        type="com.sbisec.helios.ap.brokerageMenu.customerMenu.dao.model.IfaContactInputSql002ResponseModel" >
        <result property="toiawaseNaiyou" column="TOIAWASE_NAIYOU" typeHandler="com.sbibits.earth.dao.typehandler.StringTypeHandler"/>
    </resultMap>
    <select id="selectIfaContactInputSql002" resultMap="ResultMapIfaContactInputSql002" statementType="PREPARED">
        SELECT /* @SQLID=SUB0202_0106-03#SQL002 */
             TOIAWASE_D_CD                                                          <!-- 問合せカテゴリコード（大） -->
            ,TOIAWASE_CD                                                            <!-- 問合せカテゴリコード（中） -->
            ,TOIAWASE_S_CD                                                          <!-- 問合せカテゴリコード（小） -->
            ,TOIAWASE_NAIYOU                                                        <!-- 問合せ内容 -->
            ,JUUYOUDO                                                               <!-- 重要度 -->
            ,CREAM                                                                  <!-- クレーム -->
            ,REQUEST                                                                <!-- リクエスト -->
            ,HOUKOU                                                                 <!-- 方向 -->
            ,TAIOU_STS                                                              <!-- 対応ステータス -->
            ,HOUMONBI                                                               <!-- 訪問日 -->
            ,NEXT_HOUMONBI                                                          <!-- 次回訪問予定日 -->
            ,SESSYOKU_KEIRO                                                         <!-- 接触経路 -->
            ,TOIAWASE_NO                                                            <!-- 問合せNO -->
            ,IFA_TOIAWASE_NO                                                        <!-- IFA問合せNO -->
            ,TO_CHAR(TOUROKU_NICHIJI, 'YYYY/MM/DD HH24:MI:SS') AS TOUROKU_NICHIJI   <!-- 登録日時 -->
            ,IFA_NYUURYOKU_FLG                                                      <!-- IFA入力フラグ -->
        FROM 
            CORDYS.TB_QUESTION_IFA                                                  <!-- IFA問合せ -->
        WHERE
            IFA_TOIAWASE_NO = #{req.ifaToiawaseNo}                                  <!-- IFA問合せNO -->
            AND SAKUJO_FLG = #{req.sakujoFlg}                                       <!-- 削除フラグ -->
    </select>

    <!-- 
         SQLID:Sql003
         SQL名:問合せカテゴリリスト（中）取得
         SQLタイプ:select
    -->
    <resultMap id="ResultMapIfaContactInputSql003" 
        type="com.sbisec.helios.ap.brokerageMenu.customerMenu.dao.model.IfaContactInputSql003ResponseModel" >
        <result property="toiawaseMei" column="TOIAWASE_MEI" typeHandler="com.sbibits.earth.dao.typehandler.StringTypeHandler"/>
    </resultMap>
    <select id="selectIfaContactInputSql003" resultMap="ResultMapIfaContactInputSql003" statementType="PREPARED">
        SELECT /* @SQLID=SUB0202_0106-03#SQL003 */
             TOIAWASE_CD                                                            <!-- 問合せカテゴリコード -->
            ,TOIAWASE_MEI                                                           <!-- カテゴリー名称 -->
        FROM
            CORDYS.TB_QUESTION_MASTER_IFA                                           <!-- 【IFA問合せマスタ】 -->
        WHERE
            TOIAWASE_KBN = #{req.toiawaseKbn}                                       <!-- 問合せ区分 -->
            AND IFA_SENYOU_FLG = #{req.ifaSenyouFlg}                                <!-- IFA専用フラグ -->
            AND SAKUJO_FLG = #{req.sakujoFlg}                                       <!-- 削除フラグ -->
            AND TOIAWASE_D = #{req.toiawaseD}                                       <!-- 問合せカテゴリ(大分類) -->
        ORDER BY
            SORT_NO
    </select>

    <!-- 
         SQLID:Sql004
         SQL名:問合せカテゴリリスト（小）取得
         SQLタイプ:select
    -->
    <resultMap id="ResultMapIfaContactInputSql004" 
        type="com.sbisec.helios.ap.brokerageMenu.customerMenu.dao.model.IfaContactInputSql004ResponseModel" >
        <result property="toiawaseMei" column="TOIAWASE_MEI" typeHandler="com.sbibits.earth.dao.typehandler.StringTypeHandler"/>
    </resultMap>
    <select id="selectIfaContactInputSql004" resultMap="ResultMapIfaContactInputSql004" statementType="PREPARED">
        SELECT /* @SQLID=SUB0202_0106-03#SQL004 */
             TOIAWASE_CD                                                            <!-- 問合せカテゴリコード -->
            ,TOIAWASE_MEI                                                           <!-- カテゴリー名称 -->
        FROM
            CORDYS.TB_QUESTION_MASTER_IFA                                           <!-- 【IFA問合せマスタ】 -->
        WHERE
            TOIAWASE_KBN = #{req.toiawaseKbn}                                       <!-- 問合せ区分 -->
            AND IFA_SENYOU_FLG = #{req.ifaSenyouFlg}                                <!-- IFA専用フラグ -->
            AND SAKUJO_FLG = #{req.sakujoFlg}                                       <!-- 削除フラグ -->
            AND TOIAWASE_D = #{req.toiawaseD}                                       <!-- 問合せカテゴリ(大分類) -->
            AND TOIAWASE_T = #{req.toiawaseT}                                       <!-- 問合せカテゴリ(中分類) -->
        ORDER BY
            SORT_NO
    </select>

    <!-- 
         SQLID:Sql005
         SQL名:回答情報取得
         SQLタイプ:select
    -->
    <resultMap id="ResultMapIfaContactInputSql005" 
        type="com.sbisec.helios.ap.brokerageMenu.customerMenu.dao.model.IfaContactInputSql005ResponseModel" >
        <result property="kaitouNaiyou" column="KAITOU_NAIYOU" typeHandler="com.sbibits.earth.dao.typehandler.StringTypeHandler"/>
    </resultMap>
    <select id="selectIfaContactInputSql005" resultMap="ResultMapIfaContactInputSql005" statementType="PREPARED">
        SELECT /* @SQLID=SUB0202_0106-03#SQL005 */
             IFA_TOIAWASE_NO                                                        <!-- IFA問合せNO -->
            ,IFA_KAITOU_NO                                                          <!-- IFA回答NO -->
            ,TOIAWASE_NO                                                            <!-- 問合せNO -->
            ,KAITOU_NO                                                              <!-- 回答NO -->
            ,TOUROKU_GROUP                                                          <!-- 登録グループ -->
            ,DECODE(KAITOU_NAIYOU, '-', '', KAITOU_NAIYOU) AS KAITOU_NAIYOU         <!-- 回答内容 -->
        FROM 
            CORDYS.TB_ANSWER_IFA                                                    <!-- IFA回答 -->
        WHERE
            IFA_TOIAWASE_NO = #{req.ifaToiawaseNo}                                  <!-- IFA問合せNO -->
            AND SAKUJO_FLG = #{req.sakujoFlg}                                       <!-- 削除フラグ -->
            AND TOUROKU_GROUP = #{req.tourokuGroup}                                 <!-- 登録グループ -->
        ORDER BY
             TOUROKU_NICHIJI
            ,TOIAWASE_NO
    </select>
</mapper>