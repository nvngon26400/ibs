<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<!-- 
    画面ID：SUB0202_0306-01_1
    画面名：米株信用自動振替設定入力
-->
<mapper namespace="com.sbisec.helios.ap.brokerageMenu.customerMenu.dao.mapper.IfaForeignMarginAutoTransferSettingInputMapper">
    <!-- 全角が入る場合はtypeHandler="com.sbibits.earth.dao.typehandler.StringTypeHandler"を設定すること -->
    <!-- 住所が入る場合はtype="com.sbibits.horus.ap.common.typehandler.AddressConvertHandler"を設定すること -->
    
    <resultMap id="ResultMapIfaForeignMarginAutoTransferSettingInputSql001" type="com.sbisec.helios.ap.brokerageMenu.customerMenu.dao.model.IfaForeignMarginAutoTransferSettingInputSql001ResponseModel" >
    </resultMap>
    
    <resultMap id="ResultMapIfaForeignMarginAutoTransferSettingInputSql002_1" type="com.sbisec.helios.ap.brokerageMenu.customerMenu.dao.model.IfaForeignMarginAutoTransferSettingInputSql002ResponseModel" >
    </resultMap>
    
    <resultMap id="ResultMapIfaForeignMarginAutoTransferSettingInputSql002_2" type="com.sbisec.helios.ap.brokerageMenu.customerMenu.dao.model.IfaForeignMarginAutoTransferSettingInputSql002ResponseModel" >
    </resultMap>

    <resultMap id="ResultMapIfaForeignMarginAutoTransferSettingInputSql003" type="com.sbisec.helios.ap.brokerageMenu.customerMenu.dao.model.IfaForeignMarginAutoTransferSettingInputSql003ResponseModel" >
    </resultMap>    
    
    <!-- 
        SQLID：Sql001
        SQL名：当日店頭取引売却注文のチェック
        SQLタイプ：select
    -->
    <select id="selectIfaForeignMarginAutoTransferSettingInputSql001" resultMap="ResultMapIfaForeignMarginAutoTransferSettingInputSql001" statementType="PREPARED">
        SELECT /* @SQLID=SUB0202_0306-01_1#Sql001 */
        	count(*) count
        FROM 
        	T_COUNTER_ORDER 
        WHERE 
        	BUTEN_CODE = #{req.butenCode}
       		AND ACCOUNT_NUMBER = TO_NUMBER(#{req.accountNumber})
			AND TRADE_TYPE = '1'
			AND ORDER_STATUS IN ('10','30')
			AND ORDER_DAY = TO_CHAR(IFA_DATE_UTIL.IFA_GET_DATE, 'YYYYMMDD')
    </select>
    
    <!-- 
        SQLID：Sql002_1
        SQL名：当日店頭取引買付注文の入力のチェック
        SQLタイプ：select
    -->
    <select id="selectIfaForeignMarginAutoTransferSettingInputSql002_1" resultMap="ResultMapIfaForeignMarginAutoTransferSettingInputSql002_1" statementType="PREPARED">
       
        SELECT /* @SQLID=SUB0202_0306-01_1#Sql002_1 */
        	count(*) count
        FROM 
        	T_COUNTER_ORDER
        	
        WHERE
        	BUTEN_CODE = #{req.butenCode}
       		AND ACCOUNT_NUMBER = TO_NUMBER(#{req.accountNumber})
        	AND TRADE_TYPE = '3'
			AND ORDER_STATUS IN ('10','30')
			AND ORDER_DAY = TO_CHAR(IFA_DATE_UTIL.IFA_GET_DATE, 'YYYYMMDD')
			
    </select>
    
   <!-- 
        SQLID：Sql002_2
        SQL名：外債買付代金のチェック
        SQLタイプ：select
    -->

    <select id="selectIfaForeignMarginAutoTransferSettingInputSql002_2" resultMap="ResultMapIfaForeignMarginAutoTransferSettingInputSql002_2" statementType="PREPARED">
       
        SELECT /* @SQLID=SUB0202_0306-01_1#Sql002_2 */
        	count(*) count
        FROM 
        	T_BOND_F_SALES_PRICE 
        	
        WHERE
        	BUTEN_CODE = #{req.butenCode}
       		AND ACCOUNT_NUMBER = TO_NUMBER(#{req.accountNumber})
       	    AND ORDER_TIME BETWEEN IFA_DATE_UTIL.IFA_GET_DATE + NUMTODSINTERVAL(-1 * #{req.timeInterval},'MINUTE') AND IFA_DATE_UTIL.IFA_GET_DATE
			
    </select>
    
    <!-- 
        SQLID：Sql003
        SQL名：遡る時間の取得
        SQLタイプ：select
    -->
    <select id="selectIfaForeignMarginAutoTransferSettingInputSql003" resultMap="ResultMapIfaForeignMarginAutoTransferSettingInputSql003" statementType="PREPARED">
        SELECT /* @SQLID=SUB0202_0306-01_1#Sql003 */
            NAME
        FROM 
            M_CODE 
        WHERE
            CODE_TYPE = '46'
            AND CODE_1 = '0'
            AND CODE_2 = 'LIMIT_TIME'
            AND START_DATE &lt;= IFA_DATE_UTIL.IFA_GET_SDATE('YYYYMMDD')
            AND END_DATE &gt;= IFA_DATE_UTIL.IFA_GET_SDATE('YYYYMMDD')
    </select>
    
</mapper>