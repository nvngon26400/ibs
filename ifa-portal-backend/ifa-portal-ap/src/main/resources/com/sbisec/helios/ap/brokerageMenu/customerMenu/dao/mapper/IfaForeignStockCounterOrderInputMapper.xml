        SELECT /* @SQLID=SUB0202_0302-02_1#Sql006 */
            VAR_VALUE AS CHART_URL                                                  <!-- 値 -->
        FROM
            TB_MED_SYSTEM_VARIABLE                                                  <!-- 仲介業システム値 -->
        WHERE
            VAR_NAME = 'CHAT_URL'                                                   <!-- 名称 = チャートURL -->
    </select>

    <!-- 
        SQLID：Sql007
        SQL名：株価参照URL取得
        SQLタイプ：select
    -->
    <select
        id="selectIfaForeignStockCounterOrderInputSql007"
        resultMap="ResultMapIfaForeignStockCounterOrderInputSql007"
        statementType="PREPARED"
    >
        SELECT /* @SQLID=SUB0202_0302-02_1#Sql007 */
            VAR_VALUE AS STOCK_PRICE_REFERENCE_URL                                  <!-- 値 -->
        FROM
            TB_MED_SYSTEM_VARIABLE                                                  <!-- 仲介業システム値 -->
        WHERE
            VAR_NAME = 'TICKER_URL'                                                 <!-- 名称 = 株価参照URL -->
    </select>

    <!-- 
        SQLID：Sql008
        SQL名：ワーニング約定金額取得
        SQLタイプ：select
    -->
    <select
        id="selectIfaForeignStockCounterOrderInputSql008"
        resultMap="ResultMapIfaForeignStockCounterOrderInputSql008"
        statementType="PREPARED"
    >
        SELECT /* @SQLID=SUB0202_0302-02_1#Sql008 */
            NAME AS WARNING_THRESHOLD_CONTRACT_AMOUNT                               <!-- 名称 -->
        FROM
            M_CODE                                                                  <!-- コードマスタ -->
        WHERE
            CODE_TYPE = '33'                                                        <!-- 種別 = 店頭と委託上限 -->
            AND CODE_1 = '1'                                                        <!-- コード1 = 店頭 -->
            AND CODE_2 = 'WARN_AMOUNT'                                              <!-- コード2 = ワーニング約定金額 -->
    </select>

    <!-- 
        SQLID：Sql009
