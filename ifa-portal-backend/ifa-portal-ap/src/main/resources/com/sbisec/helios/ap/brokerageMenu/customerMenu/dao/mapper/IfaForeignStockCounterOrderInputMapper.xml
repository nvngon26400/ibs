        SELECT /* @SQLID=SUB0202_0302-02_1#Sql009 */
            NAME AS FOR_CHECK_UPPER_LIMIT_CONTRACT_AMOUNT                           <!-- 名称 -->
        FROM
            M_CODE                                                                  <!-- コードマスタ -->
        WHERE
            CODE_TYPE = '33'                                                        <!-- 種別 = 店頭と委託上限 -->
            AND CODE_1 = '1'                                                        <!-- コード1 = 店頭 -->
            AND CODE_2 = 'LIMIT_AMOUNT'                                             <!-- コード2 = 上限金額 -->
    </select>

    <!-- 
        SQLID：Sql010
