{
    "version": "0.2.0",
    "configurations": [
        {
            "type": "msedge",
            "name": "Launch ifa-demo",
            "request": "launch",
            "preLaunchTask": "npm: dev",
            "url": "http://localhost:9528",
            "webRoot": "${workspaceFolder}",
            "sourceMaps": true,
            "sourceMapPathOverrides": {
                "webpack:///./src/*": "${webRoot}/src/*",
                "webpack:///./node_modules/*": "${webRoot}/node_modules/*"
            }
        }
    ]
}
