{
  "name": "vue3-element-admin",
  "version": "1.0.5",
  "private": false,
  "scripts": {
    "dev": "vue-cli-service serve",
    "build:integration": "vue-cli-service build --mode integration",
    "build:integration2": "vue-cli-service build --mode integration2",
    "build:integration3": "vue-cli-service build --mode integration3",
    "build:integrationSbibits": "vue-cli-service build --mode integrationSbibits",
    "build:prod": "vue-cli-service build",
    "build:stage": "vue-cli-service build --mode staging",
    "preview": "node build/index.js --preview",
    "svgo": "svgo -f src/icons/svg --config=src/icons/svgo.yml",
    "init:packages": "npm install --legacy-peer-deps",
    "lint": "eslint --ext .js,.vue src",
    "lint:fix": "eslint --fix --ext .js,.vue src",
    "test:unit": "jest --clearCache && vue-cli-service test:unit",
    "test:ci": "npm run lint && npm run test:unit",
    "json-server": "npm-run-all -p merge-mock boot-mock",
    "merge-mock": "nodemon --watch ./mock/json ./merge_mock_json.js",
    "boot-mock": "json-server --watch ./mock/mock.json -m middleware.js --routes routes.json"
  },
  "dependencies": {
    "@element-plus/icons-vue": "2.1.0",
    "axios": "1.6.1",
    "bignumber.js": "9.1.2",
    "chart.js": "4.4.0",
    "core-js": "3.33.2",
    "element-plus": "2.4.3",
    "express": "4.18.2",
    "jquery": "3.7.1",
    "jquery-ui-pack": "1.13.3",
    "js-cookie": "3.0.5",
    "jsonlint": "1.6.3",
    "jszip": "3.10.1",
    "moment": "2.29.4",
    "moment-timezone": "0.5.43",
    "normalize.css": "8.0.1",
    "npm-run-all": "4.1.5",
    "nprogress": "0.2.0",
    "path-to-regexp": "6.2.1",
    "pdfvuer": "2.0.1",
    "pqgridf": "3.5.1",
    "screenfull": "6.0.2",
    "script-loader": "0.7.2",
    "sortablejs": "1.15.0",
    "vue": "3.3.8",
    "vue-composable": "1.0.0-beta.24",
    "vue-devtool": "1.0.0",
    "vue-router": "4.2.5",
    "vue3-chart-v2": "0.8.3",
    "vuex": "4.1.0",
    "webpack": "4.47.0",
    "xlsx": "0.18.5"
  },
  "devDependencies": {
    "@cbcheng/secure-ls": "1.3.3",
    "@types/body-parser": "1.19.5",
    "@types/express": "4.17.21",
    "@types/jquery": "3.5.27",
    "@types/jqueryui": "1.12.20",
    "@vue/cli-plugin-babel": "4.5.19",
    "@vue/cli-plugin-eslint": "4.5.19",
    "@vue/cli-plugin-router": "4.5.19",
    "@vue/cli-plugin-vuex": "4.5.19",
    "@vue/cli-service": "4.5.19",
    "@vue/compiler-sfc": "3.3.8",
    "autoprefixer": "9.8.8",
    "babel-eslint": "10.1.0",
    "babel-jest": "29.7.0",
    "babel-plugin-dynamic-import-node": "2.3.3",
    "body-parser": "1.20.2",
    "chalk": "5.3.0",
    "chokidar": "3.5.3",
    "connect": "3.7.0",
    "eslint": "7.32.0",
    "eslint-plugin-vue": "9.18.1",
    "html-webpack-plugin": "5.5.3",
    "husky": "8.0.3",
    "json-server": "0.17.4",
    "lint-staged": "14.0.1",
    "mockjs": "1.1.0",
    "nodemon": "^3.1.0",
    "runjs": "4.4.2",
    "sass": "1.69.5",
    "sass-loader": "10.4.1",
    "script-ext-html-webpack-plugin": "2.1.5",
    "serve-static": "1.15.0",
    "svg-sprite-loader": "6.0.11",
    "svgo": "3.0.3",
    "vue-template-compiler": "2.7.15",
    "vuex-persistedstate": "4.1.0"
  },
  "eslintConfig": {
    "root": true,
    "env": {
      "node": true
    },
    "extends": [
      "plugin:vue/vue3-essential",
      "eslint:recommended"
    ],
    "parserOptions": {
      "parser": "babel-eslint"
    },
    "rules": {}
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not dead"
  ],
  "license": "MIT",
  "lint-staged": {
    "src/**/*.{js,vue}": "eslint --max-warnings=0"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  }
}
